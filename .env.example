# ── Required ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # Bot token from @BotFather
ALLOWED_CHAT_ID=             # Integer chat ID of the allowed group (discover via /chatid)
OPENAI_API_KEY=              # OpenAI API key for LLM calls
GOOGLE_CALENDAR_ID=          # Google Calendar ID (e.g. abc123@group.calendar.google.com)
GOOGLE_SERVICE_ACCOUNT_B64=  # Base64-encoded Google service-account JSON key
DATABASE_URL=                # Postgres connection string (Railway injects this automatically)

# ── Optional (have sensible defaults) ────────────────────────────────────
LLM_MODEL=gpt-4.1            # OpenAI model identifier
TIMEZONE=Asia/Singapore      # IANA timezone for scheduling
MORNING_BRIEF_TIME=08:00     # HH:MM 24h local time for the daily morning brief
